# ──────────────────────────────────────────
# FinOps Platform .gitignore
# ──────────────────────────────────────────

# ── Project-specific exclusions ──
# Documentation (local only, not uploaded to GitHub)
docs/

# NotebookLM MCP Server (development tool, not part of the platform)
NotebookLM-Antigravity/

# ── Dependencies ──
node_modules/
.pnpm-store/

# ── Build output ──
dist/
.next/
.vercel/
out/
*.tsbuildinfo

# ── Environment variables ──
.env
.env.local
.env.production
.env.staging
.env.development
.env.development.local
.env.test.local
.env.production.local
docker/.env.docker

# ── IDE / Editor ──
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Testing ──
coverage/
playwright-report/
test-results/
*.lcov

# ── Terraform / IaC ──
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# ── Docker volumes (local) ──
localstack_data/
postgres_data/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Serverless Framework ──
.serverless/

# ── AI / Development Tools ──
.gemini/
.agent/
.agents/
_agent/
_agents/
.cursor/

# ── Python (NotebookLM scripts etc.) ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/

# ── Credentials & Keys (CRITICAL SECURITY) ──
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
credentials.json
service-account*.json
*-credentials.json
*-service-key.json

# ── Database dumps & backups ──
*.sql
*.dump
*.bak
*.backup
!packages/backend/src/db/migrations/*.sql

# ── Supabase local ──
.supabase/

# ── Misc ──
*.tgz
*.tar.gz
*.zip
tmp/
temp/

CLAUDE.md