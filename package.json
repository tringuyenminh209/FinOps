{
    "name": "finops-platform",
    "version": "0.1.0",
    "private": true,
    "description": "FinOps/GreenOps Micro-SaaS Platform for Japanese SMEs",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "test": "turbo test",
        "test:unit": "turbo test:unit",
        "test:integration": "turbo test:integration",
        "test:e2e": "pnpm --filter @finops/e2e test",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "db:migrate": "pnpm --filter @finops/backend db:migrate",
        "db:seed": "pnpm --filter @finops/backend db:seed",
        "docker:up": "docker compose -f docker/docker-compose.dev.yml up -d",
        "docker:down": "docker compose -f docker/docker-compose.dev.yml down",
        "docker:logs": "docker compose -f docker/docker-compose.dev.yml logs -f",
        "clean": "turbo clean && rm -rf node_modules",
        "prepare": "husky"
    },
    "devDependencies": {
        "turbo": "^2.0.0",
        "prettier": "^3.0.0",
        "eslint": "^9.0.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "typescript": "^5.5.0"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}